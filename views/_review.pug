mixin review(review)
 .reviews__card
    .reviews__avatar
      img.reviews__avatar-img(src=`/img/users/${review.user.photo}`, alt='Jim Brown')
      h6.reviews__user=review.name
    p.reviews__text=review.review
    .reviews__rating
      each val in [1,2,3,4,5]
        svg.reviews__star(class =`reviews__star--${val<=review.rating ? 'active' : 'inactive'}`)
            use(xlink:href=`/img/icons.svg#icon-star`)
            